# ─────────────────────────────────────────────────────────────────────────────
# VoiceLayer Server — Environment Variables
# Copy this to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Your Anthropic API key — powers all voice intelligence
ANTHROPIC_API_KEY=sk-ant-

# VoiceLayer API keys issued to developers (comma-separated)
# Generate new keys with: node scripts/keygen.js
# Revoke a key by removing it from this list and redeploying.
VOICELAYER_API_KEYS=vl-demo-xxxxxxxx,vl-prod-yyyyyyyy

# ── Optional ──────────────────────────────────────────────────────────────────

# Skip API key validation entirely (local dev only — NEVER set true in production)
# VOICELAYER_DEV_MODE=true

# Port (Railway sets $PORT automatically — leave commented for Railway deploys)
PORT=3001

# Founder dashboard login
FOUNDER_PASSWORD=change_me
JWT_SECRET=change_this_to_a_random_secret

# Data directory for analytics storage
DATA_DIR=./data

# OpenAI key for Whisper STT (only if using server-side audio transcription)
# OPENAI_API_KEY=sk-
